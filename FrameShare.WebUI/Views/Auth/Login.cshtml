@{
    Layout = null; // Geralmente telas de login não usam a sidebar do layout principal
}
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - FrameShare</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Alex+Brush&family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        :root {
        --primary: #d39e97; /* Rosa Antigo / Rosé Chic */
        --primary-dark: #b87d75; /* Tom mais forte para botões e foco */
        --accent: #c9a067; /* Ouro Envelhecido do panfleto */
        --bg-main: #fbf8f7; /* Off-white Floral */
        --text-dark: #4a3e3d; /* Marrom Acinzentado Escuro */
        --text-muted: #8c7b79; /* Marrom Suave */
        --card-shadow: 0 15px 35px rgba(211, 158, 151, 0.15);
        }

        body {
        background-color: var(--bg-main);
        background-image: radial-gradient(#fcedec 1px, transparent 1px);
        background-size: 20px 20px;
        font-family: 'Montserrat', sans-serif;
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0;
        color: var(--text-dark);
        }

        .login-card {
        background: #ffffff;
        border: 1px solid #f5e6e4;
        border-radius: 24px;
        padding: 40px;
        box-shadow: var(--card-shadow);
        width: 100%;
        max-width: 400px;
        text-align: center;
        }

        .brand-logo {
        width: 60px;
        height: 60px;
        background: #fcedec;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary-dark);
        margin: 0 auto 15px;
        border: 1px solid #f5e6e4;
        }

        .login-title {
        font-family: 'Alex Brush', cursive;
        font-size: 3.2rem;
        color: var(--primary-dark);
        margin-bottom: 2px;
        }

        .login-subtitle {
        font-size: 0.75rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--accent);
        font-weight: 700;
        margin-bottom: 25px;
        }

        .form-control-custom {
        background: #faf6f5;
        border: 1px solid #f2eae9;
        border-radius: 30px;
        padding: 12px 20px;
        font-weight: 600;
        font-size: 0.9rem;
        text-align: center;
        transition: all 0.2s ease;
        color: var(--text-dark);
        }

        .form-control-custom:focus {
        outline: none;
        background-color: white;
        border-color: var(--primary);
        box-shadow: 0 0 0 4px rgba(211, 158, 151, 0.15);
        }

        .btn-login {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
        color: white;
        border: none;
        border-radius: 30px;
        padding: 12px;
        width: 100%;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-size: 0.85rem;
        margin-top: 20px;
        transition: all 0.3s;
        box-shadow: 0 6px 15px rgba(211, 158, 151, 0.3);
        }

        .btn-login:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(211, 158, 151, 0.45);
        filter: brightness(1.02);
        }

        .hint {
        font-size: 0.8rem;
        color: var(--text-muted);
        margin-top: 20px;
        line-height: 1.4;
        font-weight: 500;
        }
    </style>
</head>
<body>

    <div class="login-card">
        <div class="brand-logo">
            <i data-lucide="heart" style="fill: var(--primary-dark); width: 24px; height: 24px;"></i>
        </div>
        <h2 class="login-title">Bem-vindo(a)</h2>
        <div class="login-subtitle">Mural de Memórias</div>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger border-0 small py-2 mb-3" style="border-radius: 12px; background-color: #fee2e2; color: #ef4444; font-weight: 500;">
                <i data-lucide="alert-circle" size="14" style="vertical-align: middle; margin-right: 4px;"></i> @TempData["Error"]
            </div>
        }

        <form asp-controller="Auth" asp-action="Login" method="post">
            <div class="mb-3">
                <input type="text"
                       name="loginDigitado"
                       class="form-control form-control-custom"
                       placeholder="Digite seu nome de acesso"
                       required
                       autocomplete="off">
            </div>

            <button type="submit" class="btn-login">Acessar Evento</button>
        </form>

        <p class="hint">
            <i data-lucide="info" size="13" style="vertical-align: middle; color: var(--accent); margin-right: 2px;"></i>
            Insira seu primeiro e último nome juntos (ex: lucianasilva).
        </p>
    </div>

    <script>
        lucide.createIcons();
    </script>
</body>
</html>