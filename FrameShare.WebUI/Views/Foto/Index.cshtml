@model FrameShare.WebUI.ViewModels.IndexViewModel

@{
    ViewData["Title"] = "";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Alex+Brush&family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://unpkg.com/lucide@latest"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    :root {
    --primary: #d39e97; /* Rosa Antigo / Rosé Chic */
    --primary-dark: #b87d75; /* Tom mais forte para hover/botões */
    --accent: #c9a067; /* Ouro Envelhecido do panfleto */
    --bg-main: #fbf8f7; /* Off-white Floral */
    --text-dark: #4a3e3d; /* Marrom Acinzentado Escuro */
    --text-muted: #8c7b79; /* Marrom Suave */
    --polaroid-bg: #ffffff;
    --polaroid-shadow: 0 8px 20px rgba(74, 62, 61, 0.08);
    --toolbar-shadow: 0 8px 25px rgba(211, 158, 151, 0.12);
    }

    body {
    background-color: var(--bg-main);
    background-image: radial-gradient(#fcedec 1px, transparent 1px);
    background-size: 20px 20px;
    min-height: 100vh;
    font-family: 'Montserrat', sans-serif;
    color: var(--text-dark);
    }

    .container-custom {
    max-width: 1200px;
    margin: 0 auto;
    padding: 30px 15px;
    }

    /* HEADER ESTILO CASAMENTO */
    .wedding-title {
    font-family: 'Alex Brush', cursive;
    font-size: 3.8rem;
    color: var(--primary-dark);
    margin-bottom: 5px;
    }

    .wedding-subtitle {
    font-size: 0.95rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 600;
    }

    /* TOOLBAR REESTILIZADA */
    .toolbar-container {
    display: flex;
    gap: 15px;
    background: #ffffff;
    padding: 12px 20px;
    border-radius: 20px;
    box-shadow: var(--toolbar-shadow);
    position: sticky;
    top: 15px;
    z-index: 1000;
    margin-bottom: 40px;
    border: 1px solid #f5e6e4;
    }

    .toolbar-item {
    flex: 1;
    position: relative;
    display: flex;
    align-items: center;
    }

    .toolbar-item i {
    position: absolute;
    left: 15px;
    color: var(--accent);
    pointer-events: none;
    z-index: 5;
    }

    .custom-select {
    appearance: none;
    background-color: #faf6f5;
    border: 1px solid #f2eae9;
    border-radius: 12px;
    padding: 12px 35px 12px 45px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-dark);
    width: 100%;
    cursor: pointer;
    transition: all 0.2s ease;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    }

    .custom-select:focus {
    outline: none;
    background-color: white;
    border-color: var(--primary);
    box-shadow: 0 0 0 4px rgba(211, 158, 151, 0.15);
    }

    .toolbar-item::after {
    content: '▼';
    font-size: 0.55rem;
    position: absolute;
    right: 18px;
    color: var(--text-muted);
    pointer-events: none;
    }

    /* GALERIA POLAROID */
    .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 35px;
    padding: 20px 10px;
    transition: opacity 0.3s ease;
    }

    .photo-card.polaroid {
    position: relative;
    background: var(--polaroid-bg);
    padding: 14px 14px 28px 14px;
    border-radius: 2px;
    box-shadow: var(--polaroid-shadow);
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.15), box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
    border: 1px solid #f2eae9;
    }

    .photo-card.polaroid:nth-child(even) {
    transform: rotate(2deg);
    }

    .photo-card.polaroid:nth-child(odd) {
    transform: rotate(-2deg);
    }

    .photo-card.polaroid:hover {
    transform: scale(1.04) rotate(0deg) translateY(-8px);
    box-shadow: 0 25px 40px rgba(74, 62, 61, 0.15);
    z-index: 10;
    }

    .photo-wrapper {
    overflow: hidden;
    aspect-ratio: 1/1;
    position: relative;
    border: 1px solid #f2eae9;
    background-color: #faf6f5;
    }

    .photo-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    }

    .photo-overlay {
    position: absolute;
    bottom: 12px;
    right: 12px;
    opacity: 0;
    transition: opacity 0.25s ease, transform 0.25s ease;
    transform: translateY(5px);
    z-index: 5;
    }

    .photo-card.polaroid:hover .photo-overlay {
    opacity: 1;
    transform: translateY(0);
    }

    .btn-download-action {
    background: white;
    color: var(--primary-dark);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid #f2eae9;
    box-shadow: 0 4px 10px rgba(74, 62, 61, 0.1);
    cursor: pointer;
    transition: transform 0.2s ease, background-color 0.2s, color 0.2s;
    }

    .btn-download-action:hover {
    transform: scale(1.1);
    background-color: var(--primary);
    color: white;
    }

    .polaroid-caption {
    margin-top: 15px;
    text-align: center;
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--text-dark);
    letter-spacing: 0.5px;
    }

    /* BOTÃO CARREGAR MAIS */
    .load-more-container {
    text-align: center;
    margin: 60px 0;
    }

    .btn-load-more {
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
    color: white;
    border: none;
    padding: 14px 45px;
    border-radius: 30px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.3s;
    box-shadow: 0 8px 20px rgba(211, 158, 151, 0.35);
    display: inline-flex;
    align-items: center;
    gap: 10px;
    }

    .btn-load-more:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 12px 25px rgba(211, 158, 151, 0.45);
    filter: brightness(1.02);
    }

    .btn-load-more:disabled {
    background: #e5dbda;
    color: #a69492;
    cursor: not-allowed;
    box-shadow: none;
    }

    @@media (max-width: 768px) {
    .wedding-title {
    font-size: 2.8rem;
    }

    .toolbar-container {
    margin: 0 10px 25px;
    padding: 10px;
    gap: 8px;
    flex-direction: column;
    }

    .gallery-grid {
    grid-template-columns: 1fr;
    gap: 35px;
    padding: 20px 15px;
    }

    .photo-card.polaroid {
    padding: 14px 14px 24px 14px;
    box-shadow: 0 12px 25px rgba(74, 62, 61, 0.12);
    }

    .photo-card.polaroid:nth-child(even) {
    transform: rotate(1deg);
    }

    .photo-card.polaroid:nth-child(odd) {
    transform: rotate(-1deg);
    }

    .photo-overlay {
    opacity: 1;
    transform: translateY(0);
    bottom: 10px;
    right: 10px;
    }

    .btn-download-action {
    width: 38px;
    height: 38px;
    }
    }
</style>

<div class="container container-custom">
    <div class="text-center mb-5">
        <h2 class="wedding-title">Mural de Memórias</h2>
        <div class="wedding-subtitle">Cada clique conta um pedaço da nossa história</div>
    </div>

    <div class="toolbar-container">
        <div class="toolbar-item">
            <i data-lucide="sliders-horizontal" size="16"></i>
            <select id="ordemFotos" class="custom-select" onchange="resetarGaleria()">
                <option value="desc">Mais Recentes</option>
                <option value="asc">Mais Antigas</option>
            </select>
        </div>
    </div>

    <div id="galeriaFotos" class="gallery-grid">
        @if (Model?.Fotos != null && Model.Fotos.Any())
        {
            foreach (var foto in Model.Fotos)
            {
                <div class="photo-card polaroid">
                    <div class="photo-wrapper">
                        <img src="@foto.UrlDrive" loading="lazy" alt="Momento do Evento" />
                        <div class="photo-overlay">
                            <button class="btn-download-action" onclick="downloadImagem('@foto.UrlDrive', 'FrameShare_@(foto.Id).jpg')" title="Baixar Foto">
                                <i data-lucide="download" size="16"></i>
                            </button>
                        </div>
                    </div>
                    <div class="polaroid-caption">
                        <span>@foto.Usuario.NomeCompleto</span>
                    </div>
                </div>
            }
        }
    </div>

    <div class="load-more-container">
        <button id="btnVerMais" class="btn-load-more" onclick="carregarMais()">
            <i data-lucide="heart" id="iconLoad" size="16"></i>
            <span id="textLoad">Ver Mais Momentos</span>
        </button>
    </div>
</div>

<script>
    let paginaAtual = 1;
    const idEvento = 1;

    async function resetarGaleria() {
    const grid = document.getElementById('galeriaFotos');
    const btn = document.getElementById('btnVerMais');
    paginaAtual = 0;
    grid.style.opacity = '0.5';
    grid.innerHTML = '';
    btn.disabled = false;
    btn.innerHTML = '<i data-lucide="heart" size="16"></i> Ver Mais Momentos';
    await carregarMais(true);
    }

    async function carregarMais(isReset = false) {
    const btn = document.getElementById('btnVerMais');
    const grid = document.getElementById('galeriaFotos');
    const ordem = document.getElementById('ordemFotos').value;

    const filtroMissao = document.getElementById('filtroMissao');
    const missaoId = (filtroMissao && filtroMissao.value) ? filtroMissao.value : 0;

    btn.disabled = true;

    try {
    const url = `/Foto/BuscarFotos?idEvento=${idEvento}&pagina=${paginaAtual}&ordem=${ordem}&missaoId=${missaoId}`;
    const response = await fetch(url);

    if (!response.ok && response.status === 400) {
    const errorData = await response.json();
    throw new Error(errorData.erro || "Falha ao processar filtros da galeria pública.");
    }

    if (response.status === 204) {
    if (isReset) grid.innerHTML = '<div class="col-12 text-center py-5 text-muted small">Nenhum momento encontrado por enquanto.</div>';
    btn.innerHTML = 'Fim do Varal de Memórias ✨';
    btn.disabled = true;
    grid.style.opacity = '1';
    return;
    }

    const html = await response.text();
    if (isReset) grid.innerHTML = html;
    else grid.insertAdjacentHTML('beforeend', html);

    paginaAtual++;
    btn.disabled = false;
    btn.innerHTML = '<i data-lucide="heart" size="16"></i> Ver Mais Momentos';
    grid.style.opacity = '1';
    if (window.lucide) lucide.createIcons();
    } catch (error) {
    btn.disabled = false;
    grid.style.opacity = '1';

    Swal.fire({
    icon: 'error',
    title: 'Conexão interrompida',
    text: error.message,
    confirmButtonColor: '#d39e97'
    });
    }
    }

    async function downloadImagem(url, nomeArquivo) {
    try {
    const response = await fetch(url);
    const blob = await response.blob();
    const blobUrl = window.URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = blobUrl;
    link.download = nomeArquivo || 'frameshare-foto.jpg';
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
    window.URL.revokeObjectURL(blobUrl);
    } catch (error) {
    Swal.fire({
    icon: 'warning',
    title: 'Erro ao baixar',
    text: 'Não foi possível converter o arquivo automaticamente. Abrindo imagem em nova aba.',
    confirmButtonColor: '#b87d75'
    }).then(() => {
    window.open(url, '_blank');
    });
    }
    }
</script>