@model FrameShare.WebUI.ViewModels.IndexAdminViewModel

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&display=swap" rel="stylesheet">
<script src="https://unpkg.com/lucide@latest"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    :root {
    --primary: #ec4899;
    --secondary: #8b5cf6;
    --text-dark: #0f172a;
    --text-muted: #64748b;
    --glass-bg: rgba(255, 255, 255, 0.85);
    --glass-border: rgba(255, 255, 255, 0.6);
    --polaroid-bg: #ffffff;
    --polaroid-shadow: 0 4px 6px -1px rgba(15, 23, 42, 0.1), 0 10px 25px -5px rgba(15, 23, 42, 0.12), 0 20px 30px -10px rgba(15, 23, 42, 0.05);
    }

    body {
    background: linear-gradient(135deg, #fdf2f8 0%, #f5f3ff 100%);
    background-attachment: fixed;
    min-height: 100vh;
    font-family: 'Outfit', sans-serif;
    color: var(--text-dark);
    overflow-x: hidden;
    }

    .container-admin {
    max-width: 1100px;
    margin: 0 auto;
    padding: 10px 20px 40px 20px;
    }

    /* GLASSMORPHISM PREMIUM */
    .glass-effect {
    background: var(--glass-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--glass-border);
    border-radius: 24px;
    box-shadow: 0 10px 30px -10px rgba(15, 23, 42, 0.05);
    }

    /* APP HEADER COMPACTO E FIXO SUTIL */
    .app-header {
    padding: 20px 0;
    margin-bottom: 20px;
    border-bottom: 1px solid rgba(15, 23, 42, 0.04);
    }

    .admin-title {
    font-weight: 800;
    font-size: 1.8rem;
    letter-spacing: -0.8px;
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    }

    /* GRID DE BOTÕES DA BARRA SUPERIOR */
    .header-actions {
    display: flex;
    gap: 10px;
    }

    .btn-create-user-trigger {
    background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
    color: white !important;
    border: none;
    padding: 10px 20px;
    border-radius: 16px;
    font-weight: 700;
    font-size: 0.85rem;
    box-shadow: 0 6px 20px -4px rgba(236, 72, 153, 0.35);
    transition: all 0.2s ease;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    }

    .btn-create-user-trigger:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px -4px rgba(236, 72, 153, 0.45);
    filter: brightness(1.05);
    }

    .btn-gallery-link {
    background: white;
    color: var(--text-dark) !important;
    padding: 10px 20px;
    border-radius: 16px;
    font-weight: 700;
    font-size: 0.85rem;
    border: 1px solid rgba(15, 23, 42, 0.08);
    transition: all 0.2s ease;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.02);
    }

    .btn-gallery-link:hover {
    background: #f8fafc;
    transform: translateY(-2px);
    }

    /* MINI CARDS DE STATUS EM LINHA */
    .stats-row {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
    margin-bottom: 25px;
    }

    .stat-card-glass {
    padding: 18px 20px;
    position: relative;
    overflow: hidden;
    }

    .stat-card-glass .val {
    font-size: 2rem;
    font-weight: 800;
    color: var(--text-dark);
    line-height: 1.1;
    margin-bottom: 4px;
    }

    .stat-card-glass .lbl {
    font-size: 0.72rem;
    color: var(--text-muted);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    display: block;
    }

    .stat-card-glass::after {
    content: '';
    position: absolute;
    width: 4px;
    height: 40px;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    border-radius: 0 4px 4px 0;
    }

    .stat-card-glass.collected::after {
    background: var(--primary);
    }

    .stat-card-glass.missions::after {
    background: var(--secondary);
    }

    /* CARD CONTENEDOR DO MURAL */
    .main-mural-card {
    padding: 24px;
    border-radius: 28px;
    }

    /* GRID DA GALERIA ADAPTADO PARA GERAR RETRATO ÚNICO NO MOBILE */
    .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 40px;
    padding: 15px 5px;
    }

    /* DESIGN DE POLAROID PREMIUM ALTERNADA */
    .photo-card.polaroid {
    position: relative;
    background: var(--polaroid-bg);
    padding: 16px 16px 36px 16px;
    border-radius: 4px;
    box-shadow: var(--polaroid-shadow);
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.2), box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(15, 23, 42, 0.06);
    }

    .photo-card.polaroid:nth-child(even) {
    transform: rotate(2deg);
    }

    .photo-card.polaroid:nth-child(odd) {
    transform: rotate(-2deg);
    }

    .photo-card.polaroid:hover {
    transform: scale(1.04) rotate(0deg) translateY(-8px);
    box-shadow: 0 25px 45px rgba(15, 23, 42, 0.15);
    z-index: 10;
    }

    .photo-wrapper {
    overflow: hidden;
    aspect-ratio: 1/1;
    position: relative;
    border: 1px solid rgba(15, 23, 42, 0.08);
    background-color: #f8fafc;
    }

    .photo-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    }

    .polaroid-caption {
    margin-top: 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 2px;
    font-family: 'Courier New', Courier, monospace;
    font-weight: 900;
    }

    .polaroid-tag {
    font-size: 0.9rem;
    color: var(--text-dark);
    letter-spacing: -0.2px;
    }

    .polaroid-id {
    font-size: 0.75rem;
    color: #94a3b8;
    }

    /* OVERLAY MODERAÇÃO RÁPIDA (LIXEIRA) */
    .photo-overlay {
    position: absolute;
    bottom: 12px;
    right: 12px;
    opacity: 0;
    transition: opacity 0.2s ease, transform 0.2s ease;
    transform: translateY(5px);
    z-index: 5;
    }

    .photo-card.polaroid:hover .photo-overlay {
    opacity: 1;
    transform: translateY(0);
    }

    .btn-delete-photo-action {
    background: #ffffff;
    color: #ef4444;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(239, 68, 68, 0.15);
    box-shadow: 0 4px 15px rgba(15, 23, 42, 0.12);
    cursor: pointer;
    transition: transform 0.2s ease, background-color 0.2s, color 0.2s;
    }

    .btn-delete-photo-action:hover {
    transform: scale(1.1);
    background-color: #ef4444;
    color: white;
    }

    /* INPUTS E DIÁLOGOS CUSTOMIZADOS */
    .custom-input {
    background-color: #f8fafc;
    border: 2px solid #e2e8f0;
    border-radius: 16px;
    padding: 14px 16px;
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-dark);
    transition: all 0.2s ease;
    }

    .custom-input:focus {
    background-color: white;
    border-color: var(--primary);
    box-shadow: 0 0 0 4px rgba(236, 72, 153, 0.1);
    outline: none;
    }

    .btn-submit-user {
    background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
    color: white;
    border: none;
    padding: 14px;
    border-radius: 16px;
    font-weight: 700;
    width: 100%;
    box-shadow: 0 6px 20px rgba(236, 72, 153, 0.25);
    }

    /* 📱 CASAMENTO DE INTERFACE MOBILE RESPONSIVA */
    @@media (max-width: 768px) {
    .container-admin {
    padding: 10px 15px 30px 15px;
    }

    .app-header {
    flex-direction: column;
    align-items: flex-start !important;
    gap: 16px;
    padding-bottom: 10px;
    }

    .header-actions {
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    }

    .btn-create-user-trigger, .btn-gallery-link {
    width: 100%;
    justify-content: center;
    padding: 12px 10px;
    font-size: 0.8rem;
    border-radius: 14px;
    }

    .stats-row {
    gap: 10px;
    margin-bottom: 20px;
    }

    .stat-card-glass {
    padding: 14px 16px;
    border-radius: 18px;
    }

    .stat-card-glass .val {
    font-size: 1.6rem;
    }

    .main-mural-card {
    padding: 16px;
    border-radius: 22px;
    }
    /* Ajustado para 1 coluna cheia para dar destaque gigante na foto no celular */
    .gallery-grid {
    grid-template-columns: 1fr;
    gap: 35px;
    padding: 10px 0;
    }

    .photo-card.polaroid {
    padding: 14px 14px 28px 14px;
    box-shadow: 0 12px 24px rgba(15, 23, 42, 0.12); /* Sombra estática otimizada */
    }

    .photo-card.polaroid:nth-child(even) {
    transform: rotate(1.2deg);
    }

    .photo-card.polaroid:nth-child(odd) {
    transform: rotate(-1.2deg);
    }
    /* No mobile, removemos o hover e fixamos o botão visível de forma limpa */
    .photo-overlay {
    opacity: 1 !important;
    transform: translateY(0) !important;
    bottom: 8px;
    right: 8px;
    }

    .btn-delete-photo-action {
    width: 38px;
    height: 38px;
    background: rgba(255, 255, 255, 0.95);
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    .polaroid-caption {
    margin-top: 12px;
    }

    .polaroid-tag {
    font-size: 0.95rem;
    }

    .polaroid-id {
    display: none;
    }
    }
</style>

<div class="container-admin">
    <div class="app-header d-flex justify-content-between align-items-center flex-wrap">
        <div>
            <h1 class="admin-title mb-0">Painel Admin</h1>
            <span class="text-muted small fw-bold">FrameShare Live Event</span>
        </div>
        <div class="header-actions">
            <button type="button" class="btn-create-user-trigger" onclick="abrirModalUsuario()">
                <i data-lucide="user-plus" size="16"></i> Novo Convidado
            </button>
            <a asp-controller="Foto" asp-action="Index" class="btn-gallery-link">
                <i data-lucide="image" size="16"></i> Galeria
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success glass-effect border-0 mb-4 py-3 text-center" role="alert" style="color: #16a34a; border-radius: 16px;">
            <i data-lucide="check-circle" class="me-2" size="18"></i> @TempData["Success"]
        </div>
    }

    <div class="stats-row">
        <div class="stat-card-glass glass-effect collected">
            <span class="lbl">Fotos Coletadas</span>
            <span class="val">@(Model?.Fotos?.Count() ?? 0)</span>
        </div>
        <div class="stat-card-glass glass-effect missions">
            <span class="lbl">Missões Ativas</span>
            <span class="val">0</span>
        </div>
    </div>

    <div class="main-mural-card glass-effect mb-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="fw-bold mb-0" style="font-size: 1.1rem; color: #1e293b;">
                <i data-lucide="layers" class="me-1 text-pink" size="18" style="color: var(--primary);"></i> Enviadas recentemente
            </h5>
            <span class="badge rounded-pill bg-white text-dark border px-3 py-2 fw-bold">@DateTime.Now.ToString("dd MMM")</span>
        </div>

        <div class="gallery-grid">
            @if (Model?.Fotos != null && Model.Fotos.Any())
            {
                @foreach (var foto in Model.Fotos)
                {
                    <div class="photo-card polaroid">
                        <div class="photo-wrapper">
                            <img src="@foto.UrlDrive" loading="lazy" alt="Foto do evento" />
                            <div class="photo-overlay">
                               
                            </div>
                        </div>
                        <div class="polaroid-caption">
                            <span class="polaroid-id">@foto.Usuario.NomeCompleto</span>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-5 w-100 text-muted small col-span-all">
                    <i data-lucide="camera-off" class="d-block mx-auto mb-2 text-muted" size="32"></i>
                    Nenhuma foto enviada ainda.
                </div>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="modalCriarUsuario" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered px-4">
        <div class="modal-content glass-effect border-0" style="background: rgba(255, 255, 255, 0.98); border-radius: 28px;">
            <div class="modal-body p-4">
                <div class="text-center mb-4">
                    <div class="d-inline-block p-3 rounded-circle mb-2" style="background: #fdf2f8; color: var(--primary);">
                        <i data-lucide="user-plus" size="26"></i>
                    </div>
                    <h5 class="fw-bold mb-1">Cadastrar Convidado</h5>
                    <p class="text-muted small mb-0">A credencial de acesso (slug) será gerada automaticamente.</p>
                </div>

                <form id="formCriarUsuario" onsubmit="executarCadastroUsuario(event); return false;">
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-secondary ps-1">Nome Completo</label>
                        <input type="text" id="txtNomeCompleto" class="form-control custom-input" placeholder="Ex: Natália Garcia" required autocomplete="off">
                    </div>

                    <div class="d-flex gap-2">
                        <button type="button" class="btn w-100 py-2.5 fw-bold" data-bs-dismiss="modal"
                                style="border-radius: 14px; background: #f1f5f9; color: #64748b; border: none; font-size: 0.9rem;">
                            Cancelar
                        </button>
                        <button type="submit" class="btn-submit-user w-100 py-2.5 fw-bold" style="font-size: 0.9rem;">
                            Gerar Acesso
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalConfirmarDeletar" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered px-4">
        <div class="modal-content glass-effect border-0" style="background: rgba(255, 255, 255, 0.98); border-radius: 28px;">
            <div class="modal-body p-4 text-center">
                <div class="bg-light d-inline-block p-3 rounded-circle mb-3" style="color: #ef4444; background-color: #fee2e2 !important;">
                    <i data-lucide="alert-triangle" size="32"></i>
                </div>
                <h5 class="fw-bold mb-2">Remover Foto do Mural?</h5>
                <p class="text-muted small mb-4">Esta imagem será apagada definitivamente do feed dos convidados.</p>

                <div class="d-flex gap-2">
                    <button type="button" class="btn w-100 py-2.5 fw-bold" data-bs-dismiss="modal"
                            style="border-radius: 14px; background: #f1f5f9; color: #64748b; border: none; font-size: 0.9rem;">
                        Voltar
                    </button>
                    <button type="button" id="btnConfirmarDeletar" class="btn w-100 py-2.5 fw-bold"
                            style="border-radius: 14px; background: #ef4444; color: white; border: none; font-size: 0.9rem;">
                        Remover
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<form id="formDeletarFoto" asp-controller="Foto" asp-action="Deletar" method="post" style="display:none;">
    <input type="hidden" name="idFoto" id="inputFotoId" />
</form>

<script>
    lucide.createIcons();

    let fotoIdParaDeletar = null;
    let modalUserInstance = null;
    const modalConfirm = new bootstrap.Modal(document.getElementById('modalConfirmarDeletar'));

    document.addEventListener("DOMContentLoaded", function() {
    modalUserInstance = new bootstrap.Modal(document.getElementById('modalCriarUsuario'));
    });

    function abrirModalUsuario() {
    document.getElementById('txtNomeCompleto').value = '';
    modalUserInstance.show();
    }

    async function executarCadastroUsuario(event) {
    if (event) {
    event.preventDefault();
    event.stopPropagation();
    }

    const nomeInput = document.getElementById('txtNomeCompleto').value;

    if (!nomeInput || !nomeInput.trim()) {
    Swal.fire({
    icon: 'warning',
    title: 'Campo obrigatório',
    text: 'Por favor, digite o nome completo do convidado.',
    confirmButtonColor: '#8b5cf6'
    });
    return false;
    }

    if (modalUserInstance) {
    modalUserInstance.hide();
    }

    Swal.fire({
    title: 'Gerando credenciais...',
    text: 'Processando regras de formatação de slug.',
    allowOutsideClick: false,
    didOpen: () => { Swal.showLoading(); }
    });

    const formData = new FormData();
    formData.append("nomeCompleto", nomeInput.trim());

    try {
    const response = await fetch('/DriveTest/CriarUsuario', {
    method: 'POST',
    body: formData
    });

    const data = await response.json();

    if (!response.ok) {
    throw new Error(data.erro || "Ocorreu um erro inesperado ao salvar o usuário.");
    }

    Swal.fire({
    icon: 'success',
    title: 'Acesso Liberado! 🎫',
    text: data.mensagem,
    confirmButtonColor: '#ec4899'
    }).then(() => {
    window.location.reload();
    });

    } catch (error) {
    Swal.fire({
    icon: 'error',
    title: 'Inconsistência de Regras',
    text: error.message,
    confirmButtonColor: '#8b5cf6'
    }).then(() => {
    if (modalUserInstance) {
    modalUserInstance.show();
    }
    });
    }

    return false;
    }

    function prepararDelecaoFoto(id) {
    fotoIdParaDeletar = id;
    modalConfirm.show();
    }

    document.getElementById('btnConfirmarDeletar').addEventListener('click', function() {
    if (fotoIdParaDeletar) {
    document.getElementById('inputFotoId').value = fotoIdParaDeletar;
    document.getElementById('formDeletarFoto').submit();
    }
    });
</script>