@model FrameShare.WebUI.ViewModels.IndexAdminViewModel

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Alex+Brush&family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://unpkg.com/lucide@latest"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    :root {
    --primary: #d39e97; /* Rosa Antigo / Rosé Chic */
    --primary-dark: #b87d75; /* Tom mais forte para interações */
    --accent: #c9a067; /* Ouro Envelhecido do panfleto */
    --bg-main: #fbf8f7; /* Off-white Floral */
    --text-dark: #4a3e3d; /* Marrom Acinzentado Escuro */
    --text-muted: #8c7b79; /* Marrom Suave */
    --glass-bg: rgba(255, 255, 255, 0.95);
    --glass-border: #f5e6e4;
    --polaroid-bg: #ffffff;
    --polaroid-shadow: 0 8px 20px rgba(74, 62, 61, 0.08);
    }

    body {
    background-color: var(--bg-main);
    background-image: radial-gradient(#fcedec 1px, transparent 1px);
    background-size: 20px 20px;
    background-attachment: fixed;
    min-height: 100vh;
    font-family: 'Montserrat', sans-serif;
    color: var(--text-dark);
    overflow-x: hidden;
    }

    .container-admin {
    max-width: 1100px;
    margin: 0 auto;
    padding: 20px 20px 40px 20px;
    }

    /* GLASSMORPHISM SUAVE DO CASAMENTO */
    .glass-effect {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 20px;
    box-shadow: 0 10px 30px rgba(211, 158, 151, 0.1);
    }

    /* HEADER */
    .app-header {
    padding: 20px 0;
    margin-bottom: 25px;
    border-bottom: 1px dashed #f5e6e4;
    }

    .admin-title {
    font-family: 'Alex Brush', cursive;
    font-size: 3.2rem;
    color: var(--primary-dark);
    }

    /* BOTÕES DA BARRA SUPERIOR */
    .header-actions {
    display: flex;
    gap: 12px;
    }

    .btn-create-user-trigger {
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
    color: white !important;
    border: none;
    padding: 10px 22px;
    border-radius: 30px;
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    box-shadow: 0 6px 15px rgba(211, 158, 151, 0.35);
    transition: all 0.2s ease;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    }

    .btn-create-user-trigger:hover {
    transform: translateY(-2px);
    filter: brightness(0.98);
    box-shadow: 0 8px 20px rgba(211, 158, 151, 0.45);
    }

    .btn-gallery-link {
    background: white;
    color: var(--text-dark) !important;
    padding: 10px 22px;
    border-radius: 30px;
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border: 1px solid #f2eae9;
    transition: all 0.2s ease;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.02);
    }

    .btn-gallery-link:hover {
    background: #faf6f5;
    transform: translateY(-2px);
    border-color: var(--primary);
    }

    /* CARDS DE STATUS EM LINHA */
    .stats-row {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 15px;
    margin-bottom: 30px;
    }

    .stat-card-glass {
    padding: 20px;
    position: relative;
    }

    .stat-card-glass .val {
    font-size: 2.2rem;
    font-weight: 800;
    color: var(--text-dark);
    line-height: 1.1;
    margin-bottom: 4px;
    }

    .stat-card-glass .lbl {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    display: block;
    }

    .stat-card-glass::after {
    content: '';
    position: absolute;
    width: 4px;
    height: 35px;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    border-radius: 0 4px 4px 0;
    }

    .stat-card-glass.collected::after {
    background: var(--primary);
    }

    .stat-card-glass.missions::after {
    background: var(--accent);
    }

    /* CARD DO MURAL */
    .main-mural-card {
    padding: 25px;
    border-radius: 24px;
    }

    .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 35px;
    padding: 15px 5px;
    }

    /* DESIGN DE POLAROID */
    .photo-card.polaroid {
    position: relative;
    background: var(--polaroid-bg);
    padding: 14px 14px 28px 14px;
    border-radius: 2px;
    box-shadow: var(--polaroid-shadow);
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.2), box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
    border: 1px solid #f2eae9;
    }

    .photo-card.polaroid:nth-child(even) {
    transform: rotate(2deg);
    }

    .photo-card.polaroid:nth-child(odd) {
    transform: rotate(-2deg);
    }

    .photo-card.polaroid:hover {
    transform: scale(1.04) rotate(0deg) translateY(-6px);
    box-shadow: 0 20px 35px rgba(74, 62, 61, 0.15);
    z-index: 10;
    }

    .photo-wrapper {
    overflow: hidden;
    aspect-ratio: 1/1;
    position: relative;
    border: 1px solid #f2eae9;
    background-color: #faf6f5;
    }

    .photo-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    }

    .polaroid-caption {
    margin-top: 15px;
    text-align: center;
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--text-dark);
    letter-spacing: 0.5px;
    }

    /* BOTÃO DE EXCLUSÃO (LIXEIRA ADAPTADA) */
    .photo-overlay {
    position: absolute;
    bottom: 12px;
    right: 12px;
    opacity: 0;
    transition: opacity 0.2s ease, transform 0.2s ease;
    transform: translateY(5px);
    z-index: 5;
    }

    .photo-card.polaroid:hover .photo-overlay {
    opacity: 1;
    transform: translateY(0);
    }

    .btn-delete-photo-action {
    background: #ffffff;
    color: #ef4444;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid #fee2e2;
    box-shadow: 0 4px 12px rgba(74, 62, 61, 0.12);
    cursor: pointer;
    transition: transform 0.2s ease, background-color 0.2s, color 0.2s;
    }

    .btn-delete-photo-action:hover {
    transform: scale(1.1);
    background-color: #ef4444;
    color: white;
    }

    /* INPUTS E FORMULÁRIOS */
    .custom-input {
    background-color: #faf6f5;
    border: 1px solid #f2eae9;
    border-radius: 12px;
    padding: 14px 16px;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text-dark);
    transition: all 0.2s ease;
    }

    .custom-input:focus {
    background-color: white;
    border-color: var(--primary);
    box-shadow: 0 0 0 4px rgba(211, 158, 151, 0.15);
    outline: none;
    }

    .btn-submit-user {
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
    color: white;
    border: none;
    padding: 12px;
    border-radius: 30px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    width: 100%;
    box-shadow: 0 4px 15px rgba(211, 158, 151, 0.3);
    }

    /* RESPONSIVIDADE MOBILE */
    @@media (max-width: 768px) {
    .container-admin {
    padding: 10px 15px 30px 15px;
    }

    .app-header {
    flex-direction: column;
    align-items: flex-start !important;
    gap: 16px;
    }

    .admin-title {
    font-size: 2.6rem;
    }

    .header-actions {
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    }

    .btn-create-user-trigger, .btn-gallery-link {
    width: 100%;
    justify-content: center;
    padding: 12px 10px;
    font-size: 0.75rem;
    }

    .stats-row {
    gap: 10px;
    margin-bottom: 20px;
    }

    .stat-card-glass {
    padding: 14px 16px;
    border-radius: 16px;
    }

    .stat-card-glass .val {
    font-size: 1.8rem;
    }

    .main-mural-card {
    padding: 16px;
    border-radius: 20px;
    }

    .gallery-grid {
    grid-template-columns: 1fr;
    gap: 35px;
    padding: 10px 0;
    }

    .photo-card.polaroid {
    padding: 14px 14px 24px 14px;
    box-shadow: 0 10px 20px rgba(74, 62, 61, 0.1);
    }

    .photo-card.polaroid:nth-child(even) {
    transform: rotate(1deg);
    }

    .photo-card.polaroid:nth-child(odd) {
    transform: rotate(-1deg);
    }

    .photo-overlay {
    opacity: 1 !important;
    transform: translateY(0) !important;
    bottom: 10px;
    right: 10px;
    }

    .btn-delete-photo-action {
    width: 38px;
    height: 38px;
    background: rgba(255, 255, 255, 0.95);
    }

    .polaroid-caption {
    margin-top: 12px;
    }
    }
</style>

<div class="container-admin">
    <div class="app-header d-flex justify-content-between align-items-center flex-wrap">
        <div>
            <h1 class="admin-title mb-0">Painel Admin</h1>
            <span class="text-muted small fw-bold" style="text-transform: uppercase; letter-spacing: 1px; color: var(--accent) !important;">FrameShare Live Event</span>
        </div>
        <div class="header-actions">
            <button type="button" class="btn-create-user-trigger" onclick="abrirModalUsuario()">
                <i data-lucide="user-plus" size="15"></i> Novo Convidado
            </button>
            <a asp-controller="Foto" asp-action="Index" class="btn-gallery-link">
                <i data-lucide="image" size="15"></i> Galeria
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success glass-effect border-0 mb-4 py-3 text-center" role="alert" style="color: #16a34a; border-radius: 14px;">
            <i data-lucide="check-circle" class="me-2" size="18"></i> @TempData["Success"]
        </div>
    }

    <div class="stats-row">
        <div class="stat-card-glass glass-effect collected">
            <span class="lbl">Fotos Coletadas</span>
            <span class="val">@(Model?.Fotos?.Count() ?? 0)</span>
        </div>
        <div class="stat-card-glass glass-effect missions">
            <span class="lbl">Missões Ativas</span>
            <span class="val">0</span>
        </div>
    </div>

    <div class="main-mural-card glass-effect mb-4">
        <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2" style="border-color: #f5e6e4 !important;">
            <h5 class="fw-bold mb-0" style="font-size: 1rem; text-transform: uppercase; letter-spacing: 0.5px;">
                <i data-lucide="heart" class="me-1" size="16" style="color: var(--primary); fill: var(--primary);"></i> Enviadas Recentemente
            </h5>
            <span class="badge rounded-pill bg-white text-muted border px-3 py-2 fw-bold" style="font-size: 0.75rem;">@DateTime.Now.ToString("dd MMM")</span>
        </div>

        <div class="gallery-grid">
            @if (Model?.Fotos != null && Model.Fotos.Any())
            {
                @foreach (var foto in Model.Fotos)
                {
                    <div class="photo-card polaroid">
                        <div class="photo-wrapper">
                            <img src="@foto.UrlDrive" loading="lazy" alt="Foto do evento" />
                            <div class="photo-overlay">
                             
                            </div>
                        </div>
                        <div class="polaroid-caption">
                            <span>@foto.Usuario.NomeCompleto</span>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-5 w-100 text-muted small col-span-all">
                    <i data-lucide="camera-off" class="d-block mx-auto mb-2" size="28" style="color: var(--primary);"></i>
                    Nenhuma foto enviada ainda.
                </div>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="modalCriarUsuario" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered px-4">
        <div class="modal-content glass-effect border-0" style="background: #ffffff; border-radius: 24px;">
            <div class="modal-body p-4">
                <div class="text-center mb-4">
                    <div class="d-inline-block p-3 rounded-circle mb-2" style="background: #fcedec; color: var(--primary-dark);">
                        <i data-lucide="user-plus" size="24"></i>
                    </div>
                    <h5 class="fw-bold mb-1">Cadastrar Convidado</h5>
                    <p class="text-muted small mb-0">A credencial de acesso (slug) será gerada automaticamente.</p>
                </div>

                <form id="formCriarUsuario" onsubmit="executarCadastroUsuario(event); return false;">
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted ps-1" style="text-transform: uppercase; font-size: 0.75rem;">Nome Completo</label>
                        <input type="text" id="txtNomeCompleto" class="form-control custom-input" placeholder="Ex: Natália Garcia" required autocomplete="off">
                    </div>

                    <div class="d-flex gap-2">
                        <button type="button" class="btn w-100 py-2.5 fw-bold" data-bs-dismiss="modal"
                                style="border-radius: 30px; background: #faf6f5; color: var(--text-muted); border: 1px solid #f2eae9; font-size: 0.85rem; text-transform: uppercase;">
                            Cancelar
                        </button>
                        <button type="submit" class="btn-submit-user w-100 py-2.5 fw-bold" style="font-size: 0.85rem;">
                            Gerar Acesso
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalConfirmarDeletar" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered px-4">
        <div class="modal-content glass-effect border-0" style="background: #ffffff; border-radius: 24px;">
            <div class="modal-body p-4 text-center">
                <div class="d-inline-block p-3 rounded-circle mb-3" style="color: #ef4444; background-color: #fee2e2;">
                    <i data-lucide="alert-triangle" size="28"></i>
                </div>
                <h5 class="fw-bold mb-2">Remover Foto do Mural?</h5>
                <p class="text-muted small mb-4">Esta imagem será apagada definitivamente do feed dos convidados.</p>

                <div class="d-flex gap-2">
                    <button type="button" class="btn w-100 py-2.5 fw-bold" data-bs-dismiss="modal"
                            style="border-radius: 30px; background: #faf6f5; color: var(--text-muted); border: 1px solid #f2eae9; font-size: 0.85rem; text-transform: uppercase;">
                        Voltar
                    </button>
                    <button type="button" id="btnConfirmarDeletar" class="btn w-100 py-2.5 fw-bold"
                            style="border-radius: 30px; background: #ef4444; color: white; border: none; font-size: 0.85rem; text-transform: uppercase;">
                        Remover
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<form id="formDeletarFoto" asp-controller="Foto" asp-action="Deletar" method="post" style="display:none;">
    <input type="hidden" name="idFoto" id="inputFotoId" />
</form>

<script>
    lucide.createIcons();

    let fotoIdParaDeletar = null;
    let modalUserInstance = null;
    const modalConfirm = new bootstrap.Modal(document.getElementById('modalConfirmarDeletar'));

    document.addEventListener("DOMContentLoaded", function() {
    modalUserInstance = new bootstrap.Modal(document.getElementById('modalCriarUsuario'));
    });

    function abrirModalUsuario() {
    document.getElementById('txtNomeCompleto').value = '';
    modalUserInstance.show();
    }

    async function ejecutarCadastroUsuario(event) {
    if (event) {
    event.preventDefault();
    event.stopPropagation();
    }

    const nomeInput = document.getElementById('txtNomeCompleto').value;

    if (!nomeInput || !nomeInput.trim()) {
    Swal.fire({
    icon: 'warning',
    title: 'Campo obrigatório',
    text: 'Por favor, digite o nome completo do convidado.',
    confirmButtonColor: '#d39e97'
    });
    return false;
    }

    if (modalUserInstance) {
    modalUserInstance.hide();
    }

    Swal.fire({
    title: 'Gerando credenciais...',
    text: 'Processando regras de formatação de slug.',
    allowOutsideClick: false,
    confirmButtonColor: '#d39e97',
    didOpen: () => { Swal.showLoading(); }
    });

    const formData = new FormData();
    formData.append("nomeCompleto", nomeInput.trim());

    try {
    const response = await fetch('/DriveTest/CriarUsuario', {
    method: 'POST',
    body: formData
    });

    const data = await response.json();

    if (!response.ok) {
    throw new Error(data.erro || "Ocorreu um erro inesperado ao salvar o usuário.");
    }

    Swal.fire({
    icon: 'success',
    title: 'Acesso Liberado! 🎫',
    text: data.mensagem,
    confirmButtonColor: '#d39e97'
    }).then(() => {
    window.location.reload();
    });

    } catch (error) {
    Swal.fire({
    icon: 'error',
    title: 'Inconsistência de Regras',
    text: error.message,
    confirmButtonColor: '#b87d75'
    }).then(() => {
    if (modalUserInstance) {
    modalUserInstance.show();
    }
    });
    }

    return false;
    }

    function prepararDelecaoFoto(id) {
    fotoIdParaDeletar = id;
    modalConfirm.show();
    }

    document.getElementById('btnConfirmarDeletar').addEventListener('click', function() {
    if (fotoIdParaDeletar) {
    document.getElementById('inputFotoId').value = fotoIdParaDeletar;
    document.getElementById('formDeletarFoto').submit();
    }
    });
</script>