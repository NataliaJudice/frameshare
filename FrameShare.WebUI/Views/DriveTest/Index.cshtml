@model FrameShare.WebUI.ViewModels.IndexViewModel

@{
    ViewData["Title"] = "";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Alex+Brush&family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">
<script src="https://unpkg.com/lucide@latest"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://cdn.jsdelivr.net/npm/browser-image-compression@2.0.2/dist/browser-image-compression.min.js"></script>

<style>
    :root {
    --primary: #d39e97; /* Rosa Antigo / Rosé Chic */
    --primary-dark: #b87d75; /* Tom mais forte para hover */
    --accent: #c9a067; /* Ouro Envelhecido */
    --bg-main: #fbf8f7; /* Off-white Floral */
    --text-dark: #4a3e3d; /* Marrom Acinzentado Escuro */
    --text-muted: #8c7b79; /* Marrom Suave */
    --card-shadow: 0 10px 30px rgba(211, 158, 151, 0.15);
    --polaroid-shadow: 0 8px 20px rgba(74, 62, 61, 0.1);
    }

    body {
    background-color: var(--bg-main);
    background-image: radial-gradient(#fcedec 1px, transparent 1px);
    background-size: 20px 20px;
    min-height: 100vh;
    font-family: 'Montserrat', sans-serif;
    color: var(--text-dark);
    }

    .container-custom {
    max-width: 1200px;
    margin: 0 auto;
    padding: 30px 15px;
    }

    /* HEADER ESTILO CASAMENTO */
    .welcome-header h4 {
    font-family: 'Alex Brush', cursive;
    font-size: 3.5rem;
    color: var(--primary-dark);
    text-shadow: 1px 1px 2px rgba(0,0,0,0.05);
    }

    .wedding-subtitle {
    font-size: 1.1rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 500;
    }

    /* CARDS REESTILIZADOS */
    .glass-card {
    background: #ffffff;
    border-radius: 20px;
    padding: 25px;
    box-shadow: var(--card-shadow);
    border: 1px solid #f5e6e4;
    margin-bottom: 25px;
    position: relative;
    }

    .card-title {
    font-size: 1.2rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--text-dark);
    border-bottom: 1px dashed #f5e6e4;
    padding-bottom: 12px;
    }

    .card-title i {
    color: var(--accent);
    }

    /* ZONA DE UPLOAD IDÊNTICA AO DIVISOR DO PANFLETO */
    .upload-zone {
    border: 2px dashed var(--primary);
    border-radius: 15px;
    padding: 40px 15px;
    text-align: center;
    transition: all 0.3s ease;
    background: #fffbfb;
    cursor: pointer;
    }

    .upload-zone:hover {
    background: #fcedec;
    border-color: var(--primary-dark);
    }

    /* GALERIA POLAROID CLÁSSICA */
    .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 30px;
    padding: 15px 5px;
    }

    .photo-card.polaroid {
    background: #ffffff;
    padding: 14px 14px 28px 14px;
    border-radius: 2px;
    box-shadow: var(--polaroid-shadow);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
    border: 1px solid #f2eae9;
    }

    .photo-card.polaroid:nth-child(even) {
    transform: rotate(2deg);
    }

    .photo-card.polaroid:nth-child(odd) {
    transform: rotate(-2deg);
    }

    .photo-card.polaroid:hover {
    transform: scale(1.03) rotate(0deg) translateY(-5px);
    box-shadow: 0 20px 35px rgba(74, 62, 61, 0.15);
    z-index: 5;
    }

    .photo-wrapper {
    aspect-ratio: 1/1;
    overflow: hidden;
    border: 1px solid #f2eae9;
    background-color: #faf6f5;
    }

    .photo-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    }

    .polaroid-caption {
    margin-top: 15px;
    text-align: center;
    font-family: 'Montserrat', sans-serif;
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--text-dark);
    letter-spacing: 0.5px;
    }

    /* BOTÕES COM AS CORES DO EVENTO */
    .btn-personal-gallery {
    background: transparent;
    color: var(--primary-dark);
    border: 2px solid var(--primary);
    padding: 8px 20px;
    border-radius: 30px;
    font-weight: 600;
    font-size: 0.85rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: all 0.25s ease;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    }

    .btn-personal-gallery:hover {
    background: var(--primary);
    color: white;
    transform: translateY(-1px);
    }

    .btn-submit {
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
    color: white;
    border: none;
    padding: 14px;
    border-radius: 30px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    width: 100%;
    transition: all 0.2s;
    }

    .btn-submit:hover {
    filter: brightness(0.95);
    box-shadow: 0 5px 15px rgba(211, 158, 151, 0.4);
    }

    /* BADGES E DECORAÇÕES */
    .wedding-heart {
    color: var(--primary);
    display: inline-block;
    margin: 0 5px;
    }

    .badge-wedding {
    background-color: #fcedec;
    color: var(--primary-dark);
    border: 1px solid var(--primary);
    padding: 6px 16px;
    }

    @@media (max-width: 768px) {
    .welcome-header h4 {
    font-size: 2.7rem;
    }

    .gallery-grid {
    grid-template-columns: 1fr;
    gap: 30px;
    }

    .btn-personal-gallery {
    width: 100%;
    justify-content: center;
    }
    }
</style>

<div class="container-custom">
    <div class="topbar text-center mb-5">
        <div class="welcome-header">
            <h4 class="mb-1">Luciana <span class="wedding-heart">♥</span> Wallace</h4>
            <div class="wedding-subtitle">Mural de Memórias • 06.06.2026</div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="glass-card">
                <span class="card-title mb-4"><i data-lucide="camera"></i> Compartilhar Foto</span>
                <form id="mainUploadForm" onsubmit="enviarUploadLivre(event)">
                    <div class="upload-zone" id="dropzone" onclick="document.getElementById('fileInput').click()">
                        <div class="mb-2" style="color: var(--primary);">
                            <i data-lucide="heart" style="width: 32px; height: 32px; fill: var(--primary);"></i>
                        </div>
                        <p class="fw-bold mb-1" style="font-size: 1rem; color: var(--text-dark);">Toque para enviar sua foto livre</p>
                        <p class="text-muted small mb-0">Ajude-nos a guardar cada detalhe desse dia incrível</p>
                    </div>
                    <input type="file" id="fileInput" class="d-none" accept="image/*" />

                    <div id="previewContainer" class="mt-3 text-center" style="display: none;">
                        <img id="imagePreview" src="#" style="max-height: 220px; border-radius: 12px;" class="mb-3 shadow-sm" />
                        <button type="submit" class="btn-submit">Publicar no Varal</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="glass-card h-100 d-flex flex-column justify-content-between">
                <div>
                    <span class="card-title mb-3"><i data-lucide="info"></i> O Evento</span>
                    <div class="d-flex justify-content-between py-2 border-bottom">
                        <span class="text-muted small">Enviadas</span>
                        <span class="fw-bold" style="color: var(--text-dark);">@Model.FotosJaEnviadas</span>
                    </div>
                    <div class="d-flex justify-content-between py-2">
                        <span class="text-muted small">Mural Digital</span>
                        <span class="badge badge-wedding rounded-pill">Ativo</span>
                    </div>
                </div>
                <div class="text-center pt-3 border-top mt-3 text-muted small" style="font-family: 'Alex Brush', cursive; font-size: 1.8rem;">
                    Obrigado por celebrar conosco!
                </div>
            </div>
        </div>
    </div>

    <div class="glass-card">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
            <span class="card-title mb-0"><i data-lucide="images"></i> Momentos Eternizados</span>
            <a asp-controller="Foto" asp-action="GaleriaPessoal" class="btn-personal-gallery">
                <i data-lucide="user" size="14"></i> Galeria
            </a>
        </div>

        <div class="gallery-grid">
            @foreach (var foto in Model.Fotos)
            {
                <div class="photo-card polaroid">
                    <div class="photo-wrapper">
                        <img src="@foto.UrlDrive" loading="lazy" alt="Momento do Evento" />
                    </div>
                    <div class="polaroid-caption">
                        <span>@foto.Usuario.NomeCompleto</span>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="confirmMissionModal" tabindex="-1" aria-labelledby="modalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-lg" style="border-radius: 20px; border: 1px solid #f5e6e4;">
            <div class="modal-body text-center p-4">
                <h5 class="fw-bold mb-2" id="modalTitle" style="color: var(--text-dark);">Eternizar Missão?</h5>
                <p class="text-muted small mb-3" id="modalMissionText"></p>
                <div class="bg-light rounded-4 p-2 mb-4">
                    <img id="modalImagePreview" src="" class="img-fluid rounded-4" style="max-height: 250px; width: 100%; object-fit: cover;">
                </div>

                <div class="d-grid gap-2">
                    <button type="button" class="btn-submit" onclick="sendMissionPhoto()">Sim, enviar agora!</button>
                    <button type="button" class="btn btn-link text-muted text-decoration-none small" data-bs-dismiss="modal">Cancelar</button>
                </div>
            </div>
        </div>
    </div>
</div>

<input type="file" id="missionFileInput" accept="image/*" class="d-none">

<script>
    let selectedId = null;
    let missionModalInstance = null;

    document.addEventListener("DOMContentLoaded", function() {
    lucide.createIcons();

    const missionFileInput = document.getElementById('missionFileInput');
    const modalElement = document.getElementById('confirmMissionModal');
    missionModalInstance = new bootstrap.Modal(modalElement);

    window.triggerMissionUpload = function(id, desc) {
    selectedId = id;
    document.getElementById('modalMissionText').innerText = desc;
    missionFileInput.click();
    };

    missionFileInput.onchange = function() {
    if (this.files && this.files[0]) {
    const reader = new FileReader();
    reader.onload = (e) => {
    document.getElementById('modalImagePreview').src = e.target.result;
    missionModalInstance.show();
    };
    reader.readAsDataURL(this.files[0]);
    }
    };

    const fileInput = document.getElementById('fileInput');
    fileInput.onchange = function() {
    if (this.files && this.files[0]) {
    const reader = new FileReader();
    reader.onload = (e) => {
    document.getElementById('imagePreview').src = e.target.result;
    document.getElementById('previewContainer').style.display = 'block';
    document.getElementById('dropzone').style.display = 'none';
    };
    reader.readAsDataURL(this.files[0]);
    }
    };
    });

    const opcoesCompressao = {
    maxSizeMB: 2,
    maxWidthOrHeight: 1920,
    useWebWorker: true
    };

    async function enviarUploadLivre(event) {
    event.preventDefault();
    const fileInput = document.getElementById('fileInput');

    if (!fileInput.files || fileInput.files.length === 0) return;

    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

    // Abre o modal configurando o spinner para ficar visível e os botões totalmente ocultos
    Swal.fire({
    title: 'Otimizando imagem...',
    text: 'Preparando sua foto para o varal digital.',
    allowOutsideClick: false,
    showConfirmButton: false, // Esconde o botão de OK
    willOpen: () => {
    Swal.showLoading(); // Ativa a animação da bolinha carregando
    }
    });

    let arquivoParaEnviar = fileInput.files[0];

    try {
    if (arquivoParaEnviar.type.startsWith("image/")) {
    arquivoParaEnviar = await imageCompression(arquivoParaEnviar, opcoesCompressao);
    }
    } catch (error) {
    console.error("Erro ao otimizar imagem:", error);
    }

    // Mantém a bolinha girando enquanto atualiza o texto de progresso do upload
    if (Swal.isVisible()) {
    Swal.update({
    title: 'Enviando sua foto...',
    text: 'Salvando momento no mural de memórias.',
    showConfirmButton: false
    });
    Swal.showLoading(); // Força a bolinha a continuar ativa no update
    }

    const formData = new FormData();
    formData.append("file", arquivoParaEnviar, "upload_mural.jpg");

    try {
    const response = await fetch('/DriveTest/Index', {
    method: 'POST',
    body: formData,
    headers: { "RequestVerificationToken": token }
    });

    const data = await response.json();

    if (!response.ok) {
    throw new Error(data.mensagem || "Ocorreu uma falha no upload.");
    }

    // Sucesso: fecha o loading e exibe a mensagem final com o botão OK de volta
    Swal.fire({
    icon: 'success',
    title: 'Enviado! ✨',
    text: data.mensagem,
    confirmButtonColor: '#d39e97',
    showConfirmButton: true
    }).then(() => {
    location.reload();
    });

    } catch (error) {
    // Erro: exibe o aviso e libera o botão OK para o usuário fechar o alerta
    Swal.fire({
    icon: 'error',
    title: 'Erro no Upload',
    text: error.message,
    confirmButtonColor: '#b87d75',
    showConfirmButton: true
    });
    }
    }

    async function sendMissionPhoto() {
    if (!selectedId) return;

    const missionFileInput = document.getElementById('missionFileInput');
    if (!missionFileInput.files || missionFileInput.files.length === 0) return;

    missionModalInstance.hide();

    const formData = new FormData();
    formData.append("file", missionFileInput.files[0]);
    formData.append("idMissao", selectedId);

    // Aplica a mesma regra de exibição limpa do spinner para a foto de missão
    Swal.fire({
    title: 'Validando Missão...',
    text: 'Enviando imagem para análise do evento.',
    allowOutsideClick: false,
    showConfirmButton: false,
    willOpen: () => {
    Swal.showLoading();
    }
    });

    try {
    const response = await fetch('/DriveTest/UploadPorMissao', {
    method: 'POST',
    body: formData
    });

    const data = await response.json();

    if (!response.ok) {
    throw new Error(data.mensagem || "Não foi possível validar o envio da missão.");
    }

    Swal.fire({
    icon: 'success',
    title: 'Missão Cumprida! 🏆',
    text: data.mensagem,
    confirmButtonColor: '#d39e97',
    showConfirmButton: true
    }).then(() => {
    location.reload();
    });

    } catch (error) {
    Swal.fire({
    icon: 'error',
    title: 'Falha na Missão',
    text: error.message,
    confirmButtonColor: '#b87d75',
    showConfirmButton: true
    });
    }
    }
</script>